7:["$","section",null,{"className":"py-12 md:py-16 px-6 md:px-8 lg:px-10","id":"ethical","children":["$","div",null,{"className":"mx-auto max-w-4xl","children":[["$","h2",null,{"className":"font-serif text-2xl md:text-3xl font-semibold text-foreground mb-6","children":"Ethical Production & Labor Rights"}],["$","div",null,{"className":"space-y-6","children":[["$","p",null,{"className":"text-foreground/70 leading-relaxed","children":"We are committed to driving positive impact on people throughout our supply chain. We go beyond minimum compliance to ensure rigorous social, ethical, and environmental standards are maintained."}],["$","div",null,{"className":"space-y-4","children":[["$","div",null,{"className":"border-l-4 border-primary pl-6 py-4","children":[["$","h3",null,{"className":"font-semibold text-foreground mb-2","children":"Fair Labor Practices"}],["$","p",null,{"className":"text-foreground/70","children":"We monitor and enforce fair wages, safe working conditions, and proper treatment of workers throughout our supply chain. We are committed to strengthening the protections of all artisans involved in our production."}]]}],["$","div",null,{"className":"border-l-4 border-accent pl-6 py-4","children":[["$","h3",null,{"className":"font-semibold text-foreground mb-2","children":"Worker Welfare & Safety"}],["$","p",null,{"className":"text-foreground/70","children":"Health and safety, welfare standards, fair pay, human rights protection, and prevention of forced labor and discrimination are non-negotiable priorities in our operations."}]]}],["$","div",null,{"className":"border-l-4 border-secondary pl-6 py-4","children":[["$","h3",null,{"className":"font-semibold text-foreground mb-2","children":"Supply Chain Accountability"}],["$","p",null,{"className":"text-foreground/70","children":"We routinely audit and monitor our suppliers to ensure compliance with our standards. We provide training and support to help partners meet and exceed ethical requirements."}]]}]]}]]}