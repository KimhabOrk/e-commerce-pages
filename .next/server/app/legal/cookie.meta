{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/legal/layout,_N_T_/legal/cookie/layout,_N_T_/legal/cookie/page,_N_T_/legal/cookie"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/legal/cookie/__PAGE__",
    "/legal/cookie",
    "/legal",
    "/_index",
    "/_head"
  ]
}