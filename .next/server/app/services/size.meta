{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/services/layout,_N_T_/services/size/layout,_N_T_/services/size/page,_N_T_/services/size"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/services/size/__PAGE__",
    "/services/size",
    "/services",
    "/_index",
    "/_head"
  ]
}