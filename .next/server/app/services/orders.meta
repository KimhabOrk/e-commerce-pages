{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/services/layout,_N_T_/services/orders/layout,_N_T_/services/orders/page,_N_T_/services/orders"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/services/orders/__PAGE__",
    "/services/orders",
    "/services",
    "/_index",
    "/_head"
  ]
}