{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/support/layout,_N_T_/support/terms/layout,_N_T_/support/terms/page,_N_T_/support/terms"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/support/terms/__PAGE__",
    "/support/terms",
    "/support",
    "/_index",
    "/_head"
  ]
}