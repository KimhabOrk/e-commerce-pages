  }

  .supply-chain__steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 2rem;
  }

  .step {
    background: white;
    padding: 2rem 1.5rem;
    border-radius: 8px;
    text-align: center;
