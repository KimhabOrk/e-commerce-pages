{% section 'header' %}

<main class="responsibility-page">
  
  <!-- Hero Section -->
  <section class="page-hero">
    <div class="page-hero__wrapper">
      <h1 class="page-hero__title">Our Responsibility</h1>
      <p class="page-hero__subtitle">Commitment to Sustainability & Ethics</p>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="responsibility-intro">
    <div class="responsibility-intro__wrapper">
      <h2>Why Responsibility Matters</h2>
      <p>
        At Kimhab Ork, we believe that creating beautiful fashion comes with a responsibility to our people, our communities, 
        and our planet. Sustainability and ethical practices aren't just buzzwords for us—they're core to everything we do.
      </p>
    </div>
  </section>

  <!-- Three Pillars Section -->
  <section class="pillars">
    <div class="pillars__wrapper">
      <h2 class="pillars__title">Our Three Pillars</h2>
      <div class="pillars__grid">
        <div class="pillar">
          <div class="pillar__icon">🌍</div>
          <h3>Environmental</h3>
          <div class="pillar__content">
            <h4>Sustainable Materials</h4>
            <p>We source organic cotton, recycled fabrics, and eco-friendly alternatives. Each fabric choice is made with the environment in mind.</p>
            
            <h4>Reduced Waste</h4>
            <p>Our production process minimizes fabric waste through efficient cutting techniques and upcycling initiatives.</p>
            
            <h4>Carbon Neutral Shipping</h4>
            <p>We offset our shipping carbon footprint and are working towards carbon-neutral operations by 2025.</p>
          </div>
        </div>

        <div class="pillar">
          <div class="pillar__icon">👥</div>
          <h3>Social</h3>
          <div class="pillar__content">
            <h4>Fair Wages</h4>
            <p>Our manufacturing partners guarantee fair wages that meet or exceed local living wage standards.</p>
            
            <h4>Safe Working Conditions</h4>
            <p>We conduct regular audits to ensure safe, healthy working environments for all factory workers.</p>
            
            <h4>Community Support</h4>
            <p>We invest in community programs and education initiatives in the regions where we manufacture.</p>
          </div>
        </div>

        <div class="pillar">
          <div class="pillar__icon">♻️</div>
          <h3>Circular</h3>
          <div class="pillar__content">
            <h4>Durability First</h4>
            <p>We design pieces to last, reducing the need for frequent replacements and waste.</p>
            
            <h4>Take-Back Program</h4>
            <p>Customers can return worn pieces for recycling or upcycling into new collections.</p>
            
            <h4>Transparent Sourcing</h4>
            <p>Full transparency in our supply chain from raw materials to finished products.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Certifications & Standards -->
  <section class="certifications">
    <div class="certifications__wrapper">
      <h2 class="certifications__title">Our Certifications & Standards</h2>
      <div class="certifications__grid">
        <div class="cert-card">
          <h3>GOTS Certified</h3>
          <p>Global Organic Textile Standard certification for our organic cotton products.</p>
        </div>
        <div class="cert-card">
          <h3>Fair Trade Certified</h3>
          <p>Ensuring fair wages and working conditions throughout our supply chain.</p>
        </div>
        <div class="cert-card">
          <h3>B Corp Certified</h3>
          <p>Meeting the highest standards of social and environmental performance.</p>
        </div>
        <div class="cert-card">
          <h3>ISO 14001</h3>
          <p>Environmental management system certification for responsible operations.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Impact Metrics -->
  <section class="impact">
    <div class="impact__wrapper">
      <h2 class="impact__title">Our Impact</h2>
      <div class="impact__grid">
        <div class="metric">
          <div class="metric__value">50,000+ kg</div>
          <div class="metric__label">CO2 Offset</div>
          <div class="metric__description">Through carbon offset programs since 2020</div>
        </div>
        <div class="metric">
          <div class="metric__value">500+ Artisans</div>
          <div class="metric__label">Fairly Paid</div>
          <div class="metric__description">Supporting livelihoods across our supply chain</div>
        </div>
        <div class="metric">
          <div class="metric__value">80% Organic</div>
          <div class="metric__label">Materials</div>
          <div class="metric__description">Of our fabrics are organic or recycled</div>
        </div>
        <div class="metric">
          <div class="metric__value">20 Tons</div>
          <div class="metric__label">Waste Diverted</div>
          <div class="metric__description">From landfills through our take-back program</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Supply Chain Transparency -->
  <section class="supply-chain">
    <div class="supply-chain__wrapper">
      <h2 class="supply-chain__title">Supply Chain Transparency</h2>
      <div class="supply-chain__content">
        <p>We believe in full transparency. Here's where your Kimhab Ork piece comes from:</p>
        
        <div class="supply-chain__steps">
          <div class="step">
            <div class="step__number">1</div>
            <h4>Raw Materials</h4>
            <p>Sourced from certified organic and sustainable suppliers</p>
          </div>
          <div class="step">
            <div class="step__number">2</div>
            <h4>Fabric Production</h4>
            <p>Manufactured in certified facilities with fair labor standards</p>
          </div>
          <div class="step">
            <div class="step__number">3</div>
            <h4>Design & Cutting</h4>
            <p>Efficient cutting techniques minimize waste</p>
          </div>
          <div class="step">
            <div class="step__number">4</div>
            <h4>Assembly</h4>
            <p>Handcrafted by skilled artisans in fair-wage facilities</p>
          </div>
          <div class="step">
            <div class="step__number">5</div>
            <h4>Quality Check</h4>
            <p>Rigorous testing to ensure durability and longevity</p>
          </div>
          <div class="step">
            <div class="step__number">6</div>
            <h4>Eco-Shipping</h4>
            <p>Carbon-neutral delivery to your door</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Future Goals -->
  <section class="future-goals">
    <div class="future-goals__wrapper">
      <h2 class="future-goals__title">Our 2025-2030 Goals</h2>
      <ul class="future-goals__list">
        <li>100% organic and recycled materials in all collections</li>
        <li>Carbon neutral operations across entire supply chain</li>
        <li>Support education for 1,000+ artisans in our network</li>
        <li>Expand take-back program to 50 countries</li>
        <li>Partner with 20+ environmental organizations</li>
        <li>Achieve zero-waste manufacturing processes</li>
      </ul>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="page-cta">
    <div class="page-cta__wrapper">
      <h2>Join Our Responsibility Movement</h2>
      <p>Shop sustainably and be part of the change</p>
      <a href="/" class="page-cta__btn">Shop Responsibly</a>
    </div>
  </section>
</main>

{% section 'footer' %}

<style>
  .responsibility-page {
    min-height: 100vh;
  }

  /* Page Hero */
  .page-hero {
    background: linear-gradient(135deg, var(--color-primary, #000) 0%, var(--color-accent, #333) 100%);
    color: white;
    padding: 4rem 2rem;
    text-align: center;
  }

  .page-hero__wrapper {
    max-width: 800px;
    margin: 0 auto;
  }

  .page-hero__title {
    font-size: 3rem;
    font-weight: 700;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .page-hero__subtitle {
    font-size: 1.25rem;
    opacity: 0.9;
  }

  /* Intro Section */
  .responsibility-intro {
    padding: 4rem 2rem;
    background-color: #f5f5f5;
  }

  .responsibility-intro__wrapper {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .responsibility-intro__wrapper h2 {
    font-size: 2rem;
    margin-bottom: 1.5rem;
    color: var(--color-primary, #000);
  }

  .responsibility-intro__wrapper p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #666;
  }

  /* Pillars Section */
  .pillars {
    padding: 4rem 2rem;
  }

  .pillars__wrapper {
    max-width: 1280px;
    margin: 0 auto;
  }

  .pillars__title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 3rem;
    text-align: center;
  }

  .pillars__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .pillar {
    background: white;
    border-radius: 8px;
    padding: 2rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .pillar__icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .pillar h3 {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    color: var(--color-accent, #000);
  }

  .pillar__content h4 {
    font-size: 1rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--color-primary, #000);
  }

  .pillar__content p {
    color: #666;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  /* Certifications */
  .certifications {
    padding: 4rem 2rem;
    background-color: #f9f9f9;
  }

  .certifications__wrapper {
    max-width: 1280px;
    margin: 0 auto;
  }

  .certifications__title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 3rem;
    text-align: center;
  }

  .certifications__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
  }

  .cert-card {
    background: white;
    padding: 2rem;
    border-radius: 8px;
    text-align: center;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .cert-card h3 {
    font-size: 1.1rem;
    margin-bottom: 1rem;
    color: var(--color-accent, #000);
  }

  .cert-card p {
    color: #666;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  /* Impact Metrics */
  .impact {
    padding: 4rem 2rem;
  }

  .impact__wrapper {
    max-width: 1280px;
    margin: 0 auto;
  }

  .impact__title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 3rem;
    text-align: center;
  }

  .impact__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
  }

  .metric {
    background: linear-gradient(135deg, var(--color-primary, #000) 0%, var(--color-accent, #333) 100%);
    color: white;
    padding: 2rem;
    border-radius: 8px;
    text-align: center;
  }

  .metric__value {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .metric__label {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .metric__description {
    font-size: 0.9rem;
    opacity: 0.9;
  }

  /* Supply Chain */
  .supply-chain {
    padding: 4rem 2rem;
    background-color: #f5f5f5;
  }

  .supply-chain__wrapper {
    max-width: 1280px;
    margin: 0 auto;
  }

  .supply-chain__title {
    font-size: 2rem;
    font-weight: 700;
