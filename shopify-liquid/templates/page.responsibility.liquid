  .step__number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: var(--color-accent, #000);
    color: white;
    border-radius: 50%;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .step h4 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--color-accent, #000);
  }

  .step p {
    color: #666;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  /* Future Goals */
  .future-goals {
    padding: 4rem 2rem;
  }

  .future-goals__wrapper {
    max-width: 800px;
    margin: 0 auto;
  }

  .future-goals__title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 2rem;
    text-align: center;
  }

  .future-goals__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .future-goals__list li {
    padding: 1rem 0;
    padding-left: 2.5rem;
    position: relative;
    font-size: 1.1rem;
    line-height: 1.6;
    color: #333;
  }

  .future-goals__list li:before {
    content: '✓';
    position: absolute;
    left: 0;
    font-weight: 700;
    color: var(--color-accent, #000);
    font-size: 1.3rem;
  }

  /* Page CTA */
  .page-cta {
    background-color: var(--color-primary, #000);
    color: white;
    padding: 4rem 2rem;
    text-align: center;
  }

  .page-cta__wrapper {
    max-width: 800px;
    margin: 0 auto;
  }

  .page-cta__wrapper h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .page-cta__wrapper p {
    font-size: 1.1rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .page-cta__btn {
    display: inline-block;
    background-color: var(--color-accent, #fff);
    color: var(--color-primary, #000);
    padding: 0.75rem 2rem;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 600;
    transition: transform 0.2s;
  }

  .page-cta__btn:hover {
    transform: scale(1.05);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .page-hero__title {
      font-size: 2rem;
    }

    .pillars__title,
    .certifications__title,
    .impact__title,
    .supply-chain__title,
    .future-goals__title {
      font-size: 1.5rem;
    }

    .pillar,
    .cert-card,
    .step {
      padding: 1.5rem 1rem;
    }

    .page-cta__wrapper h2 {
      font-size: 1.75rem;
    }
  }
</style>
