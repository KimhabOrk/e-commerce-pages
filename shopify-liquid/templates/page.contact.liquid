{% comment %}
  Contact Us Page Template for Kimhab Ork
  Shopify Liquid conversion from Next.js React page
  Displays contact form, information, and FAQ
{% endcomment %}

<div class="min-h-screen">
  
  <!-- Hero Section -->
  <section class="container mx-auto px-4 md:px-6 py-12 md:py-16">
    <div class="text-center mb-12 md:mb-16">
      <h1 class="font-serif text-4xl md:text-5xl md:text-6xl font-semibold mb-4 tracking-tight">
        {{ page.title | default: 'Get in Touch' }}
      </h1>
      <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
        {{ 'pages.contact.hero_desc' | t: default: 'Have questions about our collections? We\'re here to help. Reach out to us and we\'ll get back to you as soon as possible.' }}
      </p>
    </div>

    <!-- Contact Info Cards -->
    <div class="grid grid-cols-2 gap-4 mb-16 md:mb-20">
      
      <!-- Email Card -->
      <div class="text-center">
        <div class="flex justify-center mb-4">
          <div class="p-3 bg-primary rounded-xl">
            <span class="text-foreground text-lg">✉️</span>
          </div>
        </div>
        <h3 class="font-serif text-lg font-semibold mb-2">
          {{ 'pages.contact.email_title' | t: default: 'Email' }}
        </h3>
        <p class="text-muted-foreground">
          <a href="mailto:info@kimhab.com" class="hover:text-foreground transition-colors">
            info@kimhab.com
          </a>
        </p>
      </div>

      <!-- Phone Card -->
      <div class="text-center">
        <div class="flex justify-center mb-4">
          <div class="p-3 bg-primary rounded-xl">
            <span class="text-foreground text-lg">📞</span>
          </div>
        </div>
        <h3 class="font-serif text-lg font-semibold mb-2">
          {{ 'pages.contact.phone_title' | t: default: 'Phone' }}
        </h3>
        <p class="text-muted-foreground">
          <a href="tel:+85512345678" class="hover:text-foreground transition-colors">
            +855 12 345-678
          </a>
        </p>
      </div>
    </div>

    <!-- Contact Form Section -->
    <div class="max-w-6xl mx-auto">
      <div class="bg-muted rounded-2xl p-4 md:p-10">
        <h2 class="font-serif text-2xl md:text-4xl font-semibold mb-8 text-center">
          {{ 'pages.contact.form_title' | t: default: 'Send us a Message' }}
        </h2>
        
        {% if shop.metafields.contact_form %}
          {% comment %} Use Shopify contact form metafield if available {% endcomment %}
          {{ shop.metafields.contact_form.form }}
        {% else %}
          {% comment %} Default contact form using Shopify form action {% endcomment %}
          <form method="POST" action="/contact#contact-form" class="space-y-6">
            <input type="hidden" name="contact[tags]" value="customer-inquiry">
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <!-- Name Field -->
              <div>
                <label for="name" class="block text-sm font-medium text-foreground mb-2">
                  {{ 'pages.contact.form.name' | t: default: 'Name' }} *
                </label>
                <input 
                  type="text" 
                  id="name" 
                  name="contact[name]" 
                  required 
                  class="w-full px-4 py-2 border border-border rounded-lg focus:outline-none focus:border-primary bg-background text-foreground"
                  placeholder="{{ 'pages.contact.form.name_placeholder' | t: default: 'Your name' }}"
                >
              </div>

              <!-- Email Field -->
              <div>
                <label for="email" class="block text-sm font-medium text-foreground mb-2">
                  {{ 'pages.contact.form.email' | t: default: 'Email' }} *
                </label>
                <input 
                  type="email" 
                  id="email" 
                  name="contact[email]" 
                  required 
                  class="w-full px-4 py-2 border border-border rounded-lg focus:outline-none focus:border-primary bg-background text-foreground"
                  placeholder="{{ 'pages.contact.form.email_placeholder' | t: default: 'your@email.com' }}"
                >
              </div>
            </div>

            <!-- Subject Field -->
            <div>
              <label for="subject" class="block text-sm font-medium text-foreground mb-2">
                {{ 'pages.contact.form.subject' | t: default: 'Subject' }} *
              </label>
              <input 
                type="text" 
                id="subject" 
                name="contact[body]" 
                required 
                class="w-full px-4 py-2 border border-border rounded-lg focus:outline-none focus:border-primary bg-background text-foreground"
                placeholder="{{ 'pages.contact.form.subject_placeholder' | t: default: 'How can we help?' }}"
              >
            </div>

            <!-- Message Field -->
            <div>
              <label for="message" class="block text-sm font-medium text-foreground mb-2">
                {{ 'pages.contact.form.message' | t: default: 'Message' }} *
              </label>
              <textarea 
                id="message" 
                name="contact[body]" 
                rows="6" 
                required 
                class="w-full px-4 py-2 border border-border rounded-lg focus:outline-none focus:border-primary bg-background text-foreground resize-none"
                placeholder="{{ 'pages.contact.form.message_placeholder' | t: default: 'Tell us more...' }}"
              ></textarea>
            </div>

            <!-- Submit Button -->
            <div class="flex justify-center">
              <button 
                type="submit" 
                class="px-8 py-3 bg-primary text-primary-foreground font-semibold rounded-lg hover:bg-primary/90 transition-all hover:shadow-lg"
              >
                {{ 'pages.contact.form.submit' | t: default: 'Send Message' }}
              </button>
            </div>
          </form>
        {% endif %}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="container mx-auto px-4 md:px-6 py-12 md:py-16 md:py-24 border-t border-border">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-serif text-3xl md:text-4xl font-semibold mb-12 text-center">
        {{ 'pages.contact.faq_title' | t: default: 'Frequently Asked Questions' }}
      </h2>
      
      <div class="space-y-8">
        
        <!-- FAQ Item 1: Shipping -->
        <div>
          <h3 class="font-serif text-lg md:text-xl font-semibold mb-2">
            {{ 'pages.contact.faq_01_title' | t: default: 'How long does shipping take?' }}
          </h3>
          <p class="text-muted-foreground">
            {{ 'pages.contact.faq_01_content' | t: default: 'We offer standard shipping (5-7 business days) and express shipping (2-3 business days). Shipping times may vary depending on your location.' }}
          </p>
        </div>

        <!-- FAQ Item 2: Returns -->
        <div>
          <h3 class="font-serif text-lg md:text-xl font-semibold mb-2">
            {{ 'pages.contact.faq_02_title' | t: default: 'What is your return policy?' }}
          </h3>
          <p class="text-muted-foreground">
            {{ 'pages.contact.faq_02_content' | t: default: 'We offer a 30-day return policy on all unused items in original condition. Please contact our customer service team for details on how to initiate a return.' }}
          </p>
        </div>

        <!-- FAQ Item 3: Custom Tailoring -->
        <div>
          <h3 class="font-serif text-lg md:text-xl font-semibold mb-2">
            {{ 'pages.contact.faq_03_title' | t: default: 'Do you offer custom tailoring?' }}
          </h3>
          <p class="text-muted-foreground">
            {{ 'pages.contact.faq_03_content' | t: default: 'Yes, we offer custom tailoring services for our premium collections. Please reach out to us to discuss your specific requirements.' }}
          </p>
        </div>

        <!-- FAQ Item 4: Order Tracking -->
        <div>
          <h3 class="font-serif text-lg md:text-xl font-semibold mb-2">
            {{ 'pages.contact.faq_04_title' | t: default: 'How can I track my order?' }}
          </h3>
          <p class="text-muted-foreground">
            {{ 'pages.contact.faq_04_content' | t: default: 'Once your order ships, you\'ll receive a tracking number via email. You can use this to monitor your package\'s journey.' }}
          </p>
        </div>
      </div>
    </div>
  </section>
</div>
