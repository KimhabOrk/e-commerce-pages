{% comment %}
  About Us Page Template for Kimhab Ork
  Shopify Liquid conversion from Next.js React page
  Displays company story, values, and FAQs
{% endcomment %}

<main class="flex-1">
  
  <!-- Hero Section with Gradient -->
  <section class="relative py-12 md:py-16 lg:py-32 px-6 md:px-8 lg:px-10 bg-gradient-to-b from-background to-muted/10">
    <div class="mx-auto max-w-4xl text-center">
      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold text-primary mb-6 text-balance">
        {{ page.title | default: 'Affordable Luxury for Modern Women' }}
      </h1>
      <p class="text-lg text-foreground/75 mb-8 text-balance max-w-2xl mx-auto leading-relaxed">
        {{ 'pages.about.hero_desc' | t: default: 'Kimhab Ork reimagines womenswear by combining exquisite design, premium quality materials, and sustainable practices at prices that celebrate accessibility.' }}
      </p>
    </div>
  </section>

  <!-- Our Story Section -->
  <section class="py-12 md:py-16 px-6 md:px-8 lg:px-10">
    <div class="mx-auto max-w-4xl">
      <h2 class="font-serif text-2xl md:text-3xl font-bold text-primary mb-8">
        {{ 'pages.about.story_title' | t: default: 'Our Story' }}
      </h2>
      <div class="space-y-6 text-foreground/75 leading-relaxed">
        <p>
          {{ 'pages.about.story_para_1' | t: default: 'Kimhab Ork was born from a simple belief: premium fashion should be accessible to everyone. Founded with a vision to bridge the gap between high fashion and everyday elegance, we create womenswear that empowers women to express themselves without compromise.' }}
        </p>
        <p>
          {{ 'pages.about.story_para_2' | t: default: 'Every piece in our collection is thoughtfully designed with the modern woman in mind. We draw inspiration from contemporary style, timeless elegance, and the diverse needs of women who refuse to choose between quality, design, and affordability.' }}
        </p>
        <p>
          {{ 'pages.about.story_para_3' | t: default: 'Our name reflects our commitment: Kimhab carries the essence of Khmer culture and heritage, while Ork symbolizes new beginnings and growth. Together, they represent our vision of creating something beautiful that resonates across cultures and generations.' }}
        </p>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="py-12 md:py-16 px-6 md:px-8 lg:px-10">
    <div class="mx-auto max-w-6xl">
      <h2 class="font-serif text-2xl md:text-3xl font-bold text-foreground mb-8 text-start">
        {{ 'pages.about.values_title' | t: default: 'Our Values' }}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        
        {% comment %} Quality Over Quantity {% endcomment %}
        <div class="p-6 rounded-lg bg-muted hover:bg-muted/80 transition-colors border border-border/40 hover:border-primary/40">
          <div class="w-10 h-10 text-primary mb-4">👑</div>
          <h3 class="font-semibold text-lg text-foreground mb-2">
            {{ 'pages.about.values.value_1_title' | t: default: 'Quality Over Quantity' }}
          </h3>
          <p class="text-foreground/75 text-sm leading-relaxed mb-4">
            {{ 'pages.about.values.value_1_desc' | t: default: 'We believe in creating pieces that last. Every garment is carefully crafted with premium materials and attention to detail.' }}
          </p>
          <a href="/pages/care-guides" class="text-primary hover:text-primary/80 font-semibold text-sm">
            {{ 'common.discover' | t: default: 'Discover' }} →
          </a>
        </div>

        {% comment %} Accessible Luxury {% endcomment %}
        <div class="p-6 rounded-lg bg-muted hover:bg-muted/80 transition-colors border border-border/40 hover:border-primary/40">
          <div class="w-10 h-10 text-primary mb-4">🛡️</div>
          <h3 class="font-semibold text-lg text-foreground mb-2">
            {{ 'pages.about.values.value_2_title' | t: default: 'Accessible Luxury' }}
          </h3>
          <p class="text-foreground/75 text-sm leading-relaxed mb-4">
            {{ 'pages.about.values.value_2_desc' | t: default: 'Luxury fashion should not be exclusive. We make premium womenswear affordable without compromising on design or craftsmanship.' }}
          </p>
          <a href="/" class="text-primary hover:text-primary/80 font-semibold text-sm">
            {{ 'common.shop' | t: default: 'Shop' }} →
          </a>
        </div>

        {% comment %} Sustainable Fashion {% endcomment %}
        <div class="p-6 rounded-lg bg-muted hover:bg-muted/80 transition-colors border border-border/40 hover:border-primary/40">
          <div class="w-10 h-10 text-primary mb-4">🌲</div>
          <h3 class="font-semibold text-lg text-foreground mb-2">
            {{ 'pages.about.values.value_3_title' | t: default: 'Sustainable Fashion' }}
          </h3>
          <p class="text-foreground/75 text-sm leading-relaxed mb-4">
            {{ 'pages.about.values.value_3_desc' | t: default: 'Our commitment to the environment is reflected in our material choices and production practices.' }}
          </p>
          <a href="/pages/responsibility" class="text-primary hover:text-primary/80 font-semibold text-sm">
            {{ 'common.learn' | t: default: 'Learn' }} →
          </a>
        </div>

        {% comment %} Empowered Women {% endcomment %}
        <div class="p-6 rounded-lg bg-muted hover:bg-muted/80 transition-colors border border-border/40 hover:border-primary/40">
          <div class="w-10 h-10 text-primary mb-4">👥</div>
          <h3 class="font-semibold text-lg text-foreground mb-2">
            {{ 'pages.about.values.value_4_title' | t: default: 'Empowered Women' }}
          </h3>
          <p class="text-foreground/75 text-sm leading-relaxed mb-4">
            {{ 'pages.about.values.value_4_desc' | t: default: 'We design for confident, modern women who value both style and substance. Every collection celebrates femininity and strength.' }}
          </p>
          <a href="/" class="text-primary hover:text-primary/80 font-semibold text-sm">
            {{ 'common.explore' | t: default: 'Explore' }} →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us / FAQ Section -->
  <section class="py-12 md:py-16 px-6 md:px-8 lg:px-10">
    <div class="mx-auto max-w-4xl">
      <h2 class="font-serif text-2xl md:text-3xl font-bold text-foreground mb-8 text-start">
        {{ 'pages.about.faq_title' | t: default: 'Why Choose Kimhab Ork?' }}
      </h2>
      <div class="space-y-4">
        
        {% assign faq_items = 'pages.about.faq_items' | t %}
        {% comment %} Hardcoded FAQ items - adjust to use Shopify metafields if needed {% endcomment %}
        
        <!-- FAQ Item 01 -->
        <details class="group border border-border/70 rounded-lg overflow-hidden hover:border-primary/60 transition-colors">
          <summary class="cursor-pointer px-6 py-4 bg-muted hover:bg-muted/85 transition-colors flex items-center justify-between">
            <div class="flex gap-3">
              <div class="flex-shrink-0">
                <div class="flex items-center justify-center h-7 w-7 rounded-md bg-primary/70">
                  <span class="text-sm text-white font-semibold">01</span>
                </div>
              </div>
              <h3 class="text-lg font-semibold text-foreground mb-2">
                {{ 'pages.about.faq_01_title' | t: default: 'Premium Materials' }}
              </h3>
            </div>
            <span class="text-primary">▼</span>
          </summary>
          <div class="px-6 py-4 bg-card/60 border-t border-border/70 space-y-4">
            <p class="text-foreground/75 leading-relaxed">
              {{ 'pages.about.faq_01_content' | t: default: 'We source the finest fabrics and materials, including organic cotton, sustainable silk, and responsibly-sourced textiles that feel luxurious and last longer.' }}
            </p>
          </div>
        </details>

        <!-- FAQ Item 02 -->
        <details class="group border border-border/70 rounded-lg overflow-hidden hover:border-primary/60 transition-colors">
          <summary class="cursor-pointer px-6 py-4 bg-muted hover:bg-muted/85 transition-colors flex items-center justify-between">
            <div class="flex gap-3">
              <div class="flex-shrink-0">
                <div class="flex items-center justify-center h-7 w-7 rounded-md bg-primary/70">
                  <span class="text-sm text-white font-semibold">02</span>
                </div>
              </div>
              <h3 class="text-lg font-semibold text-foreground mb-2">
                {{ 'pages.about.faq_02_title' | t: default: 'Timeless Design' }}
              </h3>
            </div>
            <span class="text-primary">▼</span>
          </summary>
          <div class="px-6 py-4 bg-card/60 border-t border-border/70 space-y-4">
            <p class="text-foreground/75 leading-relaxed">
              {{ 'pages.about.faq_02_content' | t: default: 'Our collections focus on versatile, classic silhouettes with modern details. Pieces that work today and remain relevant for years to come.' }}
            </p>
          </div>
        </details>

        <!-- FAQ Item 03 -->
        <details class="group border border-border/70 rounded-lg overflow-hidden hover:border-primary/60 transition-colors">
          <summary class="cursor-pointer px-6 py-4 bg-muted hover:bg-muted/85 transition-colors flex items-center justify-between">
            <div class="flex gap-3">
              <div class="flex-shrink-0">
                <div class="flex items-center justify-center h-7 w-7 rounded-md bg-primary/70">
                  <span class="text-sm text-white font-semibold">03</span>
                </div>
              </div>
              <h3 class="text-lg font-semibold text-foreground mb-2">
                {{ 'pages.about.faq_03_title' | t: default: 'Ethical Production' }}
              </h3>
            </div>
            <span class="text-primary">▼</span>
          </summary>
          <div class="px-6 py-4 bg-card/60 border-t border-border/70 space-y-4">
            <p class="text-foreground/75 leading-relaxed">
              {{ 'pages.about.faq_03_content' | t: default: 'We partner with manufacturers who prioritize fair wages, safe working conditions, and environmental responsibility throughout our supply chain.' }}
            </p>
          </div>
        </details>

        <!-- FAQ Item 04 -->
        <details class="group border border-border/70 rounded-lg overflow-hidden hover:border-primary/60 transition-colors">
          <summary class="cursor-pointer px-6 py-4 bg-muted hover:bg-muted/85 transition-colors flex items-center justify-between">
            <div class="flex gap-3">
              <div class="flex-shrink-0">
                <div class="flex items-center justify-center h-7 w-7 rounded-md bg-primary/70">
                  <span class="text-sm text-white font-semibold">04</span>
                </div>
              </div>
              <h3 class="text-lg font-semibold text-foreground mb-2">
                {{ 'pages.about.faq_04_title' | t: default: 'Exceptional Value' }}
              </h3>
            </div>
            <span class="text-primary">▼</span>
          </summary>
          <div class="px-6 py-4 bg-card/60 border-t border-border/70 space-y-4">
            <p class="text-foreground/75 leading-relaxed">
              {{ 'pages.about.faq_04_content' | t: default: 'Quality womenswear at accessible prices. We believe you shouldn\'t have to compromise on quality or pay luxury prices for great fashion.' }}
            </p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 md:py-16 px-6 md:px-8 lg:px-10 bg-gradient-to-r from-primary to-primary/80 text-primary-foreground">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="font-serif text-2xl md:text-3xl font-bold mb-6 text-balance">
        {{ 'pages.about.cta_title' | t: default: 'Discover Our Collections' }}
      </h2>
      <p class="text-lg mb-8 opacity-95 text-balance max-w-2xl mx-auto leading-relaxed">
        {{ 'pages.about.cta_desc' | t: default: 'Explore our thoughtfully curated womenswear collections designed for the modern woman who values quality, style, and sustainability.' }}
      </p>
      <a href="/" class="inline-block px-8 py-3 bg-primary-foreground text-primary font-semibold rounded-lg hover:shadow-lg hover:opacity-95 transition-all">
        {{ 'pages.about.cta_button' | t: default: 'Shop Now' }}
      </a>
    </div>
  </section>
</main>
