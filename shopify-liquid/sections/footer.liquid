<footer class="footer" data-section-id="{{ section.id }}" data-section-type="footer">
  <div class="footer__wrapper">
    <div class="footer__grid">
      <!-- About Section -->
      <div class="footer__column">
        <h4 class="footer__heading">{{ section.settings.about_title }}</h4>
        <div class="footer__content">{{ section.settings.about_text }}</div>
      </div>

      <!-- Quick Links -->
      <div class="footer__column">
        <h4 class="footer__heading">{{ section.settings.links_title }}</h4>
        <ul class="footer__links">
          {% for link in linklists[section.settings.footer_menu].links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>

      <!-- Newsletter -->
      <div class="footer__column">
        <h4 class="footer__heading">{{ section.settings.newsletter_title }}</h4>
        <form class="footer__form" method="post" action="/contact">
          <input type="hidden" name="form_type" value="customer">
          <input type="hidden" name="tags" value="newsletter">
          <input type="email" name="email" placeholder="Your email" required class="footer__input">
          <button type="submit" class="footer__btn">Subscribe</button>
        </form>
      </div>

      <!-- Social -->
      <div class="footer__column">
        <h4 class="footer__heading">{{ section.settings.social_title }}</h4>
        <div class="footer__social">
          {% if section.settings.facebook %}
            <a href="{{ section.settings.facebook }}" aria-label="Facebook">{% include 'icon-facebook' %}</a>
          {% endif %}
          {% if section.settings.instagram %}
            <a href="{{ section.settings.instagram }}" aria-label="Instagram">{% include 'icon-instagram' %}</a>
          {% endif %}
          {% if section.settings.twitter %}
            <a href="{{ section.settings.twitter }}" aria-label="Twitter">{% include 'icon-twitter' %}</a>
          {% endif %}
          {% if section.settings.pinterest %}
            <a href="{{ section.settings.pinterest }}" aria-label="Pinterest">{% include 'icon-pinterest' %}</a>
          {% endif %}
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer__bottom">
      <div class="footer__copyright">
        <p>&copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. All rights reserved.</p>
      </div>
      <div class="footer__bottom-links">
        {% if section.settings.show_legal_links %}
          <a href="/policies/privacy-policy">Privacy Policy</a>
          <a href="/policies/terms-of-service">Terms of Service</a>
          <a href="/policies/refund-policy">Refund Policy</a>
        {% endif %}
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-footer-bg, #f5f5f5);
    color: var(--color-footer-text, #333);
    padding: 3rem 2rem 1rem;
    margin-top: 3rem;
  }

  .footer__wrapper {
    max-width: 1280px;
    margin: 0 auto;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .footer__column {
    display: flex;
    flex-direction: column;
  }

  .footer__heading {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .footer__content,
  .footer__links {
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer__links li {
    margin-bottom: 0.5rem;
  }

  .footer__links a {
    color: var(--color-footer-text, #333);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .footer__links a:hover {
    opacity: 0.7;
  }

  .footer__form {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .footer__input {
    flex: 1;
    padding: 0.5rem;
    border: 1px solid var(--color-border, #ddd);
    border-radius: 4px;
    font-size: 0.9rem;
  }

  .footer__btn {
    padding: 0.5rem 1rem;
    background-color: var(--color-accent, #000);
    color: white;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-weight: 500;
  }

  .footer__btn:hover {
    opacity: 0.8;
  }

  .footer__social {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
  }

  .footer__social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background-color: var(--color-accent, #000);
    color: white;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .footer__social a:hover {
    opacity: 0.8;
  }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border, #ddd);
    font-size: 0.85rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer__copyright p {
    margin: 0;
  }

  .footer__bottom-links {
    display: flex;
    gap: 2rem;
  }

  .footer__bottom-links a {
    color: var(--color-footer-text, #333);
    text-decoration: none;
  }

  .footer__bottom-links a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr;
    }

    .footer__bottom {
      flex-direction: column;
      text-align: center;
    }
  }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "about_title",
      "label": "About Section Title",
      "default": "About"
    },
    {
      "type": "richtext",
      "id": "about_text",
      "label": "About Text"
    },
    {
      "type": "text",
      "id": "links_title",
      "label": "Links Section Title",
      "default": "Quick Links"
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Footer Menu",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "newsletter_title",
      "label": "Newsletter Title",
      "default": "Newsletter"
    },
    {
      "type": "text",
      "id": "social_title",
      "label": "Social Title",
      "default": "Follow Us"
    },
    {
      "type": "url",
      "id": "facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "twitter",
      "label": "Twitter URL"
    },
    {
      "type": "url",
      "id": "pinterest",
      "label": "Pinterest URL"
    },
    {
      "type": "checkbox",
      "id": "show_legal_links",
      "label": "Show Legal Links",
      "default": true
    }
  ]
}
{% endschema %}
